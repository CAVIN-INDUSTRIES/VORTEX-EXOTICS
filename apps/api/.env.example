# Env contract (local): from repo root, `pnpm run env:check:local` reads this tree’s env files
# and validates against `scripts/env-contract.mjs` (target: local). Minimum for API: `DATABASE_URL`, `JWT_SECRET`.
# Web must set `NEXT_PUBLIC_API_URL` in `apps/web/.env.local` (see `apps/web/.env.local.example`).

DATABASE_URL="postgresql://user:password@localhost:5432/vex"
# Same as DATABASE_URL locally; use direct Postgres (non-pooler) for migrations when using PgBouncer/Accelerate.
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/vex"
# Comma-separated read replica URLs for future read routing (documented; app uses DATABASE_URL today).
READ_REPLICA_URLS=

# Redis — queues (BullMQ), refresh tokens, JWT blacklist, distributed rate limits
REDIS_URL=redis://localhost:6379

# Upstash-compatible REST rate limiting (optional; falls back to Redis/ioredis or in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

JWT_SECRET="replace-with-a-long-random-production-secret"
# Access token TTL minutes (default 5). Refresh tokens are long-lived in Redis.
JWT_ACCESS_TTL_MINUTES=5
PORT=3001
# Comma-separated origins for CORS (e.g. "https://app.dealer.com,https://crm.dealer.com"). In production use real origins, not "*".
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"

# Local/dev only: allow API to start without Edmunds + MarketCheck keys (never set in production).
# SKIP_VALUATION_ENV_CHECK=1

# Public trade-in estimates (marketing /checkout) when host does not map to a tenant via custom domain
PUBLIC_APPRAISAL_TENANT_ID=
# Max public appraisal submissions per tenant per UTC day (usage guardrail; default 1000)
PUBLIC_APPRAISAL_DAILY_MAX=1000
# Per-IP requests per minute for POST/GET /public/quick-appraisal (default 60)
PUBLIC_APPRAISAL_IP_MAX_PER_MIN=60

# Third-party vehicle valuation (required in production unless SKIP_VALUATION_ENV_CHECK is set)
EDMUNDS_API_KEY=
EDMUNDS_SECRET=
MARKETCHECK_API_KEY=

# Stripe (SaaS checkout + webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard (see apps/api/src/lib/stripe.ts)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# Optional: secret for /webhooks/sms and /webhooks/email (send as X-Webhook-Secret header or ?secret=)
# WEBHOOK_SECRET=your-secret

# Fortellis (CDK developer exchange)
FORTELLIS_CLIENT_ID=
FORTELLIS_CLIENT_SECRET=
FORTELLIS_SUBSCRIPTION_ID=
FORTELLIS_TOKEN_URL=https://auth.fortellis.io/oauth2/token
FORTELLIS_API_BASE_URL=https://api.fortellis.io
FORTELLIS_WEBHOOK_SECRET=
FORTELLIS_SANDBOX=true
CDK_SANDBOX=true
# Optional CDK Drive probe: pnpm --filter @vex/api run smoke:cdk-drive
# CDK_DRIVE_SMOKE_PATH=/inventory/v1/vehicles
# CDK_DRIVE_SMOKE_METHOD=GET
# CDK_DRIVE_SMOKE_BODY_JSON={"example":"key"}

# Tekion APC
TEKION_CLIENT_ID=
TEKION_CLIENT_SECRET=
TEKION_SUBSCRIPTION_ID=
TEKION_TOKEN_URL=https://auth.tekioncloud.com/oauth2/token
TEKION_API_BASE_URL=https://api.apc.tekioncloud.com
TEKION_WEBHOOK_SECRET=
TEKION_SANDBOX=true

# Reynolds RCI
REYNOLDS_CLIENT_ID=
REYNOLDS_CLIENT_SECRET=
REYNOLDS_SUBSCRIPTION_ID=
REYNOLDS_TOKEN_URL=https://auth.reynolds.com/oauth2/token
REYNOLDS_API_BASE_URL=https://api.reynolds.com
REYNOLDS_WEBHOOK_SECRET=
REYNOLDS_SANDBOX=true

# Dealertrack (Cox OpenTrack)
DEALERTRACK_CLIENT_ID=
DEALERTRACK_CLIENT_SECRET=
DEALERTRACK_SUBSCRIPTION_ID=
DEALERTRACK_TOKEN_URL=https://auth.coxautoinc.com/oauth2/token
DEALERTRACK_API_BASE_URL=https://api.dealertrack.com
DEALERTRACK_WEBHOOK_SECRET=
DEALERTRACK_SANDBOX=true

# Deployment / platform (PUBLIC_WEB_URL used for Stripe checkout + billing portal return URLs)
PUBLIC_WEB_URL=
NEXT_PUBLIC_WEB_URL=
NEXT_PUBLIC_API_URL=

# Notifications (Resend email + optional SMS placeholder)
RESEND_API_KEY=
RESEND_FROM=
SMS_PROVIDER=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

RATE_LIMIT_POINTS_PER_TENANT=1000
RATE_LIMIT_WINDOW_SEC=60
ONBOARDING_CAPTCHA_SECRET=
PILOT_AUTO_APPROVE_LIMIT=20

# Pilot self-serve: require email OTP unless set to 1 (dev/e2e only)
# PILOT_SKIP_EMAIL_VERIFY=1

# Internal metrics: GET /dealer/pilots (same value on web for /api/investor/pilot-network proxy)
INTERNAL_PILOT_METRICS_KEY=
