# Production API env contract: see `scripts/env-contract.mjs` (target: production). Examples are non-secret templates.
# Verify with: `pnpm run env:check:production` (export required keys; see root README).

DATABASE_URL=
DIRECT_DATABASE_URL=
JWT_SECRET=
REDIS_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CORS_ORIGIN=https://vexdomain.com
PUBLIC_WEB_URL=https://vexdomain.com
NEXT_PUBLIC_API_URL=https://api.vexdomain.com

# Valuation providers (required in production; SKIP_VALUATION_ENV_CHECK is dev-only and forbidden by production contract)
EDMUNDS_API_KEY=
EDMUNDS_SECRET=
MARKETCHECK_API_KEY=

# Optional but likely needed for a real production launch
RESEND_API_KEY=
RESEND_FROM=concierge@vexdomain.com
INTERNAL_PILOT_METRICS_KEY=

# Managed media / cinematic asset storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://media.vexdomain.com
